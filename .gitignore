node_modules/
.DS_Store
*.log

# Adapter-Cache: Rohdokumente (PDF, XML, XLSX) werden hier zwischengelagert,
# damit Re-Runs nicht jedes Mal beim Quellsystem neu ziehen müssen.
.cache/

# Claude-Code lokale Session-Artefakte (Scheduled-Task-Locks etc.)
.claude/

# Secrets — never commit (siehe .env.example fuer die Felder)
.env

# Forschungsphase: keine Daten-Artefakte im Repo committen.
# Bis schriftliche Erlaubnis vorliegt (siehe README, Abschnitt „Status"), bleiben
# alle vom Adapter erzeugten JSONs und generierten RSS-Feeds nur lokal.
wiki/**/*.json
wiki/**/*.xml

# UPDATES.md ist die Diff-Zusammenfassung der Daten-Commits — solange keine Daten
# im Repo sind, hat sie keine Aussagekraft und bleibt lokal.
UPDATES.md
