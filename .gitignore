node_modules/
.DS_Store
*.log

# Adapter-Cache: Rohdokumente (PDF, XML, XLSX) werden hier zwischengelagert,
# damit Re-Runs nicht jedes Mal beim Quellsystem neu ziehen müssen.
.cache/

# Claude-Code lokale Session-Artefakte (Scheduled-Task-Locks etc.)
.claude/

# Secrets — never commit (siehe .env.example fuer die Felder)
.env

# Daten-Veröffentlichungs-Policy (siehe README, Abschnitt „Status"):
#
# Standard: alle adapter-erzeugten JSONs + RSS-Feeds bleiben lokal …
wiki/**/*.json
wiki/**/*.xml
#
# … außer für Parlamente, deren Quell-robots.txt das nicht ausschließt:
!wiki/bundestag/**
!wiki/mecklenburg-vorpommern/**
!wiki/thueringen/**
!wiki/sachsen/**
!wiki/metadata.json
#
# Forschungsphase (robots.txt = "Disallow: /") — Daten nur lokal, bis
# eine schriftliche Erlaubnis der Parlamentsdokumentation vorliegt:
#   • Sachsen-Anhalt PADOKA
#   • Brandenburg STARWEB
# Diese werden durch die wiki/**/*.json-Regel oben weiter ausgeschlossen.
